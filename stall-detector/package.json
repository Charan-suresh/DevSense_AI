{
  "name": "stall-detector",
  "displayName": "Stall Detector",
  "description": "Developer stall detector",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Stall Detector",
      "properties": {
        "stallDetector.websocketUrl": {
          "type": "string",
          "default": "ws://localhost:8000/ws",
          "description": "WebSocket URL for the stall payload server."
        }
      }
    },
    "commands": [
      {
        "command": "stall-detector.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "stall-detector.applyFix",
        "title": "Apply Fix"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}